# ── AgentClaw Environment Variables ──

# Gateway authentication (required for Web UI / API access)
API_KEY=your-secret-key-here

# ── LLM Provider (at least one required) ──

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / DeepSeek / Kimi / Qwen (OpenAI-compatible)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini
# GEMINI_API_KEY=...

# Default model name (used by the primary provider)
# DEFAULT_MODEL=

# ── Vision Provider (optional, for image understanding) ──
# VISION_API_KEY=
# VISION_BASE_URL=
# VISION_MODEL=
# VISION_PROVIDER=openai  # openai | claude | gemini

# ── Fast Provider (optional, for simple chat routing) ──
# FAST_API_KEY=
# FAST_BASE_URL=
# FAST_MODEL=
# FAST_PROVIDER=openai

# ── Embedding (optional, for semantic memory search) ──
# VOLCANO_EMBEDDING_KEY=
# VOLCANO_EMBEDDING_MODEL=doubao-embedding-vision-250615

# ── Gateway ──
PORT=3100
# HOST=0.0.0.0
# MAX_ITERATIONS=15  # Agent loop max tool-call rounds (default: 15)

# ── Telegram Bot (optional) ──
# TELEGRAM_BOT_TOKEN=

# ── WhatsApp Bot (optional) ──
# WHATSAPP_ENABLED=true

# ── DingTalk Bot (optional, Stream mode) ──
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=
# DINGTALK_ALLOWED_USERS=staffId1,staffId2  # required! empty = block all

# ── Feishu Bot (optional, WebSocket mode) ──
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_ALLOWED_USERS=ou_xxx,ou_yyy  # required! empty = block all

# ── Google Services (optional, for calendar/tasks skills) ──
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# ── Web Search ──
# Search engines are now configured in Settings > Search.
# Legacy env vars (SEARXNG_URL, SERPER_API_KEY) are auto-migrated on first run.

# ── Email (optional, for email skill) ──
# EMAIL_IMAP_HOST=
# EMAIL_SMTP_HOST=
# EMAIL_USER=
# EMAIL_PASSWORD=
