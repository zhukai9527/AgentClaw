{
  "$schema": "https://raw.githubusercontent.com/nicedriverclub/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "AgentClaw",
  "version": "1.5.5",
  "identifier": "com.agentclaw.desktop",
  "build": {
    "devUrl": "http://localhost:3200",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentClaw",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://localhost:* http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http://localhost:*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["data/agents/**"],
    "externalBin": ["binaries/agentclaw-server"],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
